APP_ENV=test
APP_SECRET=test_secret_key_for_testing_only

# Database
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_pass
POSTGRES_DB=auth_db_test
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgresql:5432/${POSTGRES_DB}

# JWT
JWT_SECRET_KEY=/app/config/jwt/private-test.pem
JWT_PUBLIC_KEY=/app/config/jwt/public-test.pem
JWT_PASSPHRASE=test_passphrase

# Redis
REDIS_URL=redis://redis:6379

# Messenger
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

SENTRY_DSN=
